<%= form_with model: @registration_form, url: registrations_path, local: true do |form| %>
  <% if @registration_form.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(@registration_form.errors.count, "error") %> 件のエラーが発生しました:</h2>
      <ul>
        <% @registration_form.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <fieldset>
    <legend>User情報</legend>
    <div class="field">
      <%= form.label :user_name, "ユーザー名" %><br>
      <%= form.text_field :user_name %>
    </div>

    <div class="field">
      <%= form.label :email, "メールアドレス" %><br>
      <%= form.email_field :email %>
    </div>

    <div class="field">
      <%= form.label :password, "パスワード" %><br>
      <%= form.password_field :password %>
    </div>
  </fieldset>

  <fieldset>
    <legend>Profile情報</legend>
    <div class="field">
      <%= form.label :bio, "自己紹介" %><br>
      <%= form.text_area :bio %>
    </div>

    <div class="field">
      <%= form.label :age, "年齢" %><br>
      <%= form.number_field :age %>
    </div>
  </fieldset>

  <div class="actions">
    <%= form.submit "登録" %>
  </div>
<% end %>
